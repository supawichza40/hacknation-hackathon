# VC Brain — environment template (copy to .env.local; never commit real keys)

# LLM calls run via the local `claude` CLI headless (no API key on this machine).
# Path to the claude binary if not on PATH:
CLAUDE_CLI_BIN=claude

# SQLite (better-sqlite3) file location
DATABASE_PATH=./data/vc-brain.db

# Tavily — live founder web sourcing (R7). Redeem code HackNationJuly at
# tavily.com → Billing → Project plan (8,000 credits). Optional — captured
# scan replay is the on-stage fallback if unset.
TAVILY_API_KEY=

# ElevenLabs voice brief (P0 pre-rendered MP3). Optional — text fallback if unset.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Demo-lite auth (plan §0.5 d13): single hard-coded investor login. A presence-
# checked session cookie — a demo gate, NOT real auth (the JSON APIs stay
# unauthenticated). These defaults are the visible on-screen login hint.
DEMO_INVESTOR_EMAIL=investor@foundergraph.demo
DEMO_INVESTOR_PASSWORD=demo
