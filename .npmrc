# Force better-sqlite3's native addon to compile from source on every install/ci
# so its ABI always matches the running Node. Node 26 = NODE_MODULE_VERSION 147;
# the fetched prebuilt is ABI 127 (Node 22) and 500s `next start` DB routes with
# ERR_DLOPEN_FAILED. Scoped by package name (prebuild-install rc.js:
# buildFromSource === pkg.name) so sharp and other native deps keep prebuilts.
build_from_source=better-sqlite3
